pipeline {
  agent any

  stages {
    stage('SonarQube analysis') {
      environment {
        SONAR_PROJECT_KEY = 'Contact-Manager'
        SONAR_PROJECT_NAME = 'Contact Manager'
        SONAR_SCANNER_OPTS = '-Dsonar.sources=src -Dsonar.tests=src -Dsonar.sources.exclusions=**/*.spec.ts -Dsonar.projectKey=${SONAR_PROJECT_KEY} -Dsonar.projectName="${SONAR_PROJECT_NAME}"'
      }
      steps {
        script {
          scannerHome = tool 'SonarQubeServer'
        }
        withSonarQubeEnv('scannerHome') {
          sh "${scannerHome}/bin/sonar-scanner ${SONAR_SCANNER_OPTS}"
        }
      }
    }

    stage('Quality Gate') {
      steps {
        script {
          timeout(time: 5, unit: 'MINUTES') {
            def qg = waitForQualityGate()
            if (qg.status != 'OK') {
              error "Pipeline aborted due to quality gate failure: ${qg.status}"
            }
          }
        }
      }
    }
  }

  post {
    always {
      echo "Pipeline done"
    }
    success {
      echo "Success: SonarQube scan passed."
    }
    failure {
      echo "Failure: check SonarQube and build logs."
    }
  }
}