pipeline {
  agent any

  environment {
    // SonarQube server configured in Jenkins (Manage Jenkins > Configure System > SonarQube servers)
    SONAR_HOST_URL = "${SONAR_HOST_URL ?: 'http://sonarqube.local:9000'}"
    SONAR_LOGIN    = credentials('sonarqube-token') // credentials ID
  }

  stages {
    stage('Checkout') {
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: '*/main']],
          userRemoteConfigs: [[
            url: 'https://github.com/your-org/contact-manager.git',
            credentialsId: 'git-credentials-id' // optional if public
          ]]
        ])
      }
    }

    stage('Build') {
      steps {
        script {
          // Angular example
          sh 'npm install'
          sh 'npm run build -- --prod'
          // Change to your actual command if .NET, Java, etc.
        }
      }
    }

    stage('SonarQube analysis') {
      environment {
        SCANNER_OPTS = '-Dsonar.sources=src -Dsonar.tests=src -Dsonar.projectKey=contact-manager -Dsonar.projectName=contact-manager'
      }
      steps {
        withSonarQubeEnv('MySonarQubeServer') {
          sh "sonar-scanner -Dsonar.host.url=${SONAR_HOST_URL} -Dsonar.login=${SONAR_LOGIN} ${SCANNER_OPTS}"
        }
      }
    }

    stage('Quality Gate') {
      steps {
        timeout(time: 5, unit: 'MINUTES') {
          waitForQualityGate abortPipeline: true
        }
      }
    }
  }

  post {
    always {
      echo "Pipeline done"
    }
    success {
      echo "Success: SonarQube scan passed."
    }
    failure {
      echo "Failure: check SonarQube and build logs."
    }
  }
}